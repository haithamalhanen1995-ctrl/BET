rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Users profiles
    match /users/{userId} {
      allow read, write: if true;
    }
    
    // Deposit Requests
    match /depositRequests/{depositId} {
      allow read, write: if true;
    }
    
    // Withdrawal Requests
    match /withdrawalRequests/{withdrawalId} {
      allow read, write: if true;
    }
    
    // VIP Tiers config
    match /vipTiers/{tierLevel} {
      allow read, write: if true;
    }
    
    // Tasks Products list
    match /products/{productId} {
      allow read, write: if true;
    }
    
    // App Settings parameters
    match /settings/{settingId} {
      allow read, write: if true;
    }

    // Support Chats threads
    match /supportChats/{userId} {
      allow read, write: if true;
      
      // Messages inside a support chat thread
      match /messages/{messageId} {
        allow read, write: if true;
      }
    }
  }
}
